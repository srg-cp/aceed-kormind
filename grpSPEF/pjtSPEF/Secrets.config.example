<?xml version="1.0" encoding="utf-8"?>
<!--
  Plantilla de secretos. NO pongas valores reales aquí.

  Pasos:
  1. Copia este archivo como "Secrets.config" en esta misma carpeta (junto a Web.config).
  2. Pega tus valores reales en Secrets.config.
  3. Secrets.config está en .gitignore: nunca se sube al repositorio.

  Web.config lo carga automáticamente vía <appSettings file="Secrets.config">.
  Si el archivo no existe, la app arranca igual (las integraciones de Google quedan inactivas).
-->
<appSettings>
  <!-- Google AI Studio: https://aistudio.google.com/apikey (empieza con AIza...) -->
  <add key="Gemini:ApiKey" value="" />
  <add key="Gemini:ModeloCalificacion" value="gemini-3.1-flash-lite" />
  <add key="Gemini:Modelo" value="gemini-3.5-flash" />

  <!-- Anthropic Console: https://console.anthropic.com/settings/keys (empieza con sk-ant-...) -->
  <add key="Claude:ApiKey" value="sk-ant-..." />
  <add key="Claude:Modelo" value="claude-opus-4-8" />
  <add key="Claude:ModeloCalificacion" value="claude-haiku-4-5-20251001" />

  <!-- Google Cloud Console > APIs y servicios > Credenciales > ID de cliente OAuth 2.0 (tipo: Aplicación web) -->
  <add key="GoogleAuth:ClientId" value="" />
  <add key="GoogleAuth:ClientSecret" value="" />
</appSettings>
