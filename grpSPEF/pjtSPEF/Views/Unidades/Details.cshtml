@model pjtSPEF.Models.Entities.Unidad
@{
    ViewBag.Title = Model.Nombre;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis cursos", Url.Action("Index", "Cursos")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.Curso.Nombre, Url.Action("Details", "Cursos", new { id = Model.CursoId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Unidad " + Model.Numero + " — " + Model.Nombre)
})

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Unidad @Model.Numero — @Model.Nombre</h2>
    <div>
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-outline-secondary">Editar unidad</a>
        <a href="@Url.Action("Create", "TiposEvaluacion", new { unidadId = Model.Id })" class="btn btn-primary">Nuevo tipo de evaluación</a>
    </div>
</div>

<h5 class="mt-4">Tipos de evaluación</h5>
@if (!Model.TiposEvaluacion.Any())
{
    <div class="alert alert-info">
        Esta unidad aún no tiene tipos de evaluación (p. ej. Examen teórico, Práctica calificada).
    </div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Nombre</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tipo in Model.TiposEvaluacion.OrderBy(t => t.Nombre))
            {
                <tr>
                    <td><a href="@Url.Action("Details", "TiposEvaluacion", new { id = tipo.Id })">@tipo.Nombre</a></td>
                    <td class="text-end">
                        <a href="@Url.Action("Details", "TiposEvaluacion", new { id = tipo.Id })" class="btn btn-sm btn-outline-primary">Abrir</a>
                        <a href="@Url.Action("Edit", "TiposEvaluacion", new { id = tipo.Id })" class="btn btn-sm btn-outline-secondary">Editar</a>
                        @using (Html.BeginForm("Delete", "TiposEvaluacion", new { id = tipo.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('¿Eliminar este tipo de evaluación con sus exámenes?');" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
