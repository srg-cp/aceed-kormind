@model pjtSPEF.Models.ViewModels.UnidadFormViewModel
@{
    ViewBag.Title = "Nueva unidad";
    var curso = (pjtSPEF.Models.Entities.Curso)ViewBag.Curso;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis cursos", Url.Action("Index", "Cursos")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(curso.Nombre, Url.Action("Details", "Cursos", new { id = curso.Id })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Nueva unidad")
})

<h2>Nueva unidad en @curso.Nombre</h2>

<div class="row">
    <div class="col-md-6">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.CursoId)
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Numero, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Numero, new { @class = "form-control", type = "number", min = "1" })
                @Html.ValidationMessageFor(m => m.Numero, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", autofocus = "autofocus" })
                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Crear unidad</button>
            <a href="@Url.Action("Details", "Cursos", new { id = Model.CursoId })" class="btn btn-outline-secondary">Cancelar</a>
        }
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
