@model pjtSPEF.Models.ViewModels.UnidadFormViewModel
@{
    ViewBag.Title = "Editar unidad";
    var curso = (pjtSPEF.Models.Entities.Curso)ViewBag.Curso;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis periodos", Url.Action("Index", "Periodos")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(curso.Periodo.Nombre, Url.Action("Details", "Periodos", new { id = curso.PeriodoId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(curso.Nombre, Url.Action("Details", "Cursos", new { id = curso.Id })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Unidad " + Model.Numero, Url.Action("Details", new { id = Model.Id })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Editar")
})

<h2>Editar unidad</h2>

<div class="row">
    <div class="col-md-6">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Numero, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Numero, new { @class = "form-control", type = "number", min = "1" })
                @Html.ValidationMessageFor(m => m.Numero, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Guardar cambios</button>
            <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-outline-secondary">Cancelar</a>
        }
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
