@model IEnumerable<pjtSPEF.Models.Entities.Curso>
@{
    ViewBag.Title = "Mis cursos";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h2>Mis cursos</h2>
    <a href="@Url.Action("Create")" class="btn btn-primary">Nuevo curso</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Aún no tienes cursos. Crea el primero para empezar a organizar tus exámenes.
    </div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Periodo</th>
                <th>Creado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var curso in Model)
            {
                <tr>
                    <td><a href="@Url.Action("Details", new { id = curso.Id })">@curso.Nombre</a></td>
                    <td>@(curso.Periodo ?? "—")</td>
                    <td>@curso.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <a href="@Url.Action("Details", new { id = curso.Id })" class="btn btn-sm btn-outline-primary">Abrir</a>
                        <a href="@Url.Action("Edit", new { id = curso.Id })" class="btn btn-sm btn-outline-secondary">Editar</a>
                        @using (Html.BeginForm("Delete", "Cursos", new { id = curso.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('¿Eliminar este curso con todas sus unidades y exámenes?');" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
