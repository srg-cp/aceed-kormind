@model pjtSPEF.Models.Entities.Curso
@{
    ViewBag.Title = Model.Nombre;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis periodos", Url.Action("Index", "Periodos")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.Periodo.Nombre, Url.Action("Details", "Periodos", new { id = Model.PeriodoId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.Nombre)
})

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">@Model.Nombre</h2>
        <span class="text-muted">Periodo: @Model.Periodo.Nombre</span>
    </div>
    <div>
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-outline-secondary">Editar curso</a>
        <a href="@Url.Action("Create", "Unidades", new { cursoId = Model.Id })" class="btn btn-primary">Nueva unidad</a>
    </div>
</div>

<h5 class="mt-4">Unidades</h5>
@if (!Model.Unidades.Any())
{
    <div class="alert alert-info">Este curso aún no tiene unidades.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th style="width: 8rem">Número</th>
                <th>Nombre</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var unidad in Model.Unidades.OrderBy(u => u.Numero))
            {
                <tr>
                    <td>Unidad @unidad.Numero</td>
                    <td><a href="@Url.Action("Details", "Unidades", new { id = unidad.Id })">@unidad.Nombre</a></td>
                    <td class="text-end">
                        <a href="@Url.Action("Details", "Unidades", new { id = unidad.Id })" class="btn btn-sm btn-outline-primary">Abrir</a>
                        <a href="@Url.Action("Edit", "Unidades", new { id = unidad.Id })" class="btn btn-sm btn-outline-secondary">Editar</a>
                        @using (Html.BeginForm("Delete", "Unidades", new { id = unidad.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('¿Eliminar esta unidad con sus evaluaciones y exámenes?');" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
