@model pjtSPEF.Models.ViewModels.CursoFormViewModel
@{
    ViewBag.Title = "Nuevo curso";
    var periodo = (pjtSPEF.Models.Entities.Periodo)ViewBag.Periodo;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis periodos", Url.Action("Index", "Periodos")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(periodo.Nombre, Url.Action("Details", "Periodos", new { id = periodo.Id })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Nuevo curso")
})

<h2>Nuevo curso en @periodo.Nombre</h2>

<div class="row">
    <div class="col-md-6">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.PeriodoId)
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", autofocus = "autofocus" })
                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Crear curso</button>
            <a href="@Url.Action("Details", "Periodos", new { id = Model.PeriodoId })" class="btn btn-outline-secondary">Cancelar</a>
        }
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
