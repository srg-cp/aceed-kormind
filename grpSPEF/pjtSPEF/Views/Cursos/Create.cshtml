@model pjtSPEF.Models.ViewModels.CursoFormViewModel
@{
    ViewBag.Title = "Nuevo curso";
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis cursos", Url.Action("Index")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Nuevo curso")
})

<h2>Nuevo curso</h2>

<div class="row">
    <div class="col-md-6">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", autofocus = "autofocus" })
                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Periodo, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Periodo, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Periodo, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Crear curso</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancelar</a>
        }
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
