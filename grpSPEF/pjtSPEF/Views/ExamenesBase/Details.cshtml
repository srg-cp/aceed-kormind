@model pjtSPEF.Models.Entities.ExamenBase
@{
    ViewBag.Title = Model.Titulo;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis periodos", Url.Action("Index", "Periodos")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.TipoEvaluacion.Unidad.Curso.Periodo.Nombre, Url.Action("Details", "Periodos", new { id = Model.TipoEvaluacion.Unidad.Curso.PeriodoId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.TipoEvaluacion.Unidad.Curso.Nombre, Url.Action("Details", "Cursos", new { id = Model.TipoEvaluacion.Unidad.CursoId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Unidad " + Model.TipoEvaluacion.Unidad.Numero, Url.Action("Details", "Unidades", new { id = Model.TipoEvaluacion.UnidadId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.TipoEvaluacion.Nombre, Url.Action("Details", "TiposEvaluacion", new { id = Model.TipoEvaluacionId })),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.Titulo)
})

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">@Model.Titulo</h2>
    <div>
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-outline-secondary">Editar</a>
        @if (!string.IsNullOrEmpty(Model.ArchivoRef))
        {
            <a href="@Url.Action("Descargar", new { id = Model.Id })" class="btn btn-outline-primary">Descargar PDF</a>
            <a href="@Url.Action("Calibrar", "Calibracion", new { id = Model.Id })" class="btn btn-primary">Calibrar clave</a>
            <a href="@Url.Action("Index", "Evaluaciones", new { examenBaseId = Model.Id })" class="btn btn-success">Entregas de estudiantes</a>
        }
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

<div class="row">
    <div class="col-md-6">
        <table class="table">
            <tr>
                <th style="width: 12rem">Estado</th>
                <td>
                    @switch (Model.Estado)
                    {
                        case pjtSPEF.Models.Entities.EstadoExamen.Borrador:
                            <span class="badge bg-secondary">Borrador</span>
                            <span class="text-muted small">— pendiente de calibrar la clave</span>
                            break;
                        case pjtSPEF.Models.Entities.EstadoExamen.Calibrado:
                            <span class="badge bg-info">Calibrado</span>
                            break;
                        case pjtSPEF.Models.Entities.EstadoExamen.Activo:
                            <span class="badge bg-success">Activo</span>
                            break;
                    }
                </td>
            </tr>
            <tr>
                <th>Nota máxima</th>
                <td>@Model.NotaMaxima.ToString("0.##")</td>
            </tr>
            <tr>
                <th>Archivo</th>
                <td>@(Model.ArchivoNombreOriginal ?? "—")</td>
            </tr>
            <tr>
                <th>Páginas</th>
                <td>@(Model.TotalPaginas.HasValue ? Model.TotalPaginas.ToString() : "—")</td>
            </tr>
            <tr>
                <th>Creado</th>
                <td>@Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            @if (Model.FechaModificacion.HasValue)
            {
                <tr>
                    <th>Última modificación</th>
                    <td>@Model.FechaModificacion.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </table>

    </div>
</div>

<h4 class="mt-4">Clave de corrección</h4>
@{ var preguntas = Model.PreguntasClave == null ? new List<pjtSPEF.Models.Entities.PreguntaClave>() : Model.PreguntasClave.OrderBy(p => p.Numero).ToList(); }
@if (preguntas.Count == 0)
{
    <div class="alert alert-light border">
        Este examen aún no tiene clave. Usa <strong>Calibrar clave</strong> para extraerla del PDF con IA
        (o cargarla a mano) — sin clave no se pueden calificar entregas.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th style="width: 4rem">N.º</th>
                <th>Enunciado</th>
                <th>Respuesta esperada / criterios</th>
                <th style="width: 7rem">Puntaje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in preguntas)
            {
                <tr>
                    <td>@p.Numero</td>
                    <td style="white-space: pre-wrap">@p.Enunciado</td>
                    <td style="white-space: pre-wrap">@p.RespuestaEsperada</td>
                    <td>@p.Puntaje.ToString("0.##")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td></td>
                <td colspan="2" class="text-end fw-bold">Total:</td>
                <td class="fw-bold">@preguntas.Sum(p => p.Puntaje).ToString("0.##")</td>
            </tr>
        </tfoot>
    </table>
}
