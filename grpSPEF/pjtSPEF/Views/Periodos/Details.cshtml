@model pjtSPEF.Models.Entities.Periodo
@{
    ViewBag.Title = Model.Nombre;
}

@Html.Partial("_Breadcrumb", new List<pjtSPEF.Models.ViewModels.BreadcrumbItem>
{
    new pjtSPEF.Models.ViewModels.BreadcrumbItem("Mis periodos", Url.Action("Index")),
    new pjtSPEF.Models.ViewModels.BreadcrumbItem(Model.Nombre)
})

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Periodo @Model.Nombre</h2>
    <div>
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-outline-secondary">Editar periodo</a>
        <a href="@Url.Action("Create", "Cursos", new { periodoId = Model.Id })" class="btn btn-primary">Nuevo curso</a>
    </div>
</div>

<h5 class="mt-4">Cursos</h5>
@if (Model.Cursos == null || !Model.Cursos.Any())
{
    <div class="alert alert-info">Este periodo aún no tiene cursos.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Creado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var curso in Model.Cursos)
            {
                <tr>
                    <td><a href="@Url.Action("Details", "Cursos", new { id = curso.Id })">@curso.Nombre</a></td>
                    <td>@curso.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <a href="@Url.Action("Details", "Cursos", new { id = curso.Id })" class="btn btn-sm btn-outline-primary">Abrir</a>
                        <a href="@Url.Action("Edit", "Cursos", new { id = curso.Id })" class="btn btn-sm btn-outline-secondary">Editar</a>
                        @using (Html.BeginForm("Delete", "Cursos", new { id = curso.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('¿Eliminar este curso con todas sus unidades y exámenes?');" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
