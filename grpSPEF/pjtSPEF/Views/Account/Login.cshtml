@{
    ViewBag.Title = "Iniciar sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body text-center p-5">
                <h1 class="h3 mb-3">SPEF</h1>
                <p class="text-muted">Sistema de corrección automática de exámenes</p>
                <hr />
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                @using (Html.BeginForm("ExternalLogin", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        Entrar con Google
                    </button>
                }
                <p class="text-muted small mt-3 mb-0">
                    Inicia sesión con tu cuenta de Google. La primera vez se te pedirá autorizar
                    el acceso a Google Drive, donde se guardarán los PDFs de los exámenes.
                </p>
            </div>
        </div>
    </div>
</div>
