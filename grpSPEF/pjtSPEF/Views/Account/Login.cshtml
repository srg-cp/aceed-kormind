@{
    ViewBag.Title = "Iniciar sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body text-center p-5">
                <h1 class="h3 mb-3">SPEF</h1>
                <p class="text-muted">Sistema de corrección automática de exámenes</p>
                <hr />
                @using (Html.BeginForm("LoginDev", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        Entrar (modo desarrollo)
                    </button>
                }
                <p class="text-muted small mt-3 mb-0">
                    El inicio de sesión con Google estará disponible cuando se configuren
                    las credenciales de OAuth.
                </p>
            </div>
        </div>
    </div>
</div>
